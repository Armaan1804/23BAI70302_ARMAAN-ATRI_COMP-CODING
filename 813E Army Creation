#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

const int MAXN = 100005;
int n, k, a[MAXN], b[MAXN], q;
vector<int> tree[4 * MAXN];
vector<int> pos[MAXN];

void build(int node, int l, int r) {
    if (l == r) {
        tree[node].push_back(b[l]);
        return;
    }
    int mid = (l + r) / 2;
    build(2 * node, l, mid);
    build(2 * node + 1, mid + 1, r);
    tree[node].resize(r - l + 1);
    merge(tree[2 * node].begin(), tree[2 * node].end(),
          tree[2 * node + 1].begin(), tree[2 * node + 1].end(),
          tree[node].begin());
}

int query(int node, int l, int r, int ql, int qr, int val) {
    if (ql > r || qr < l) return 0;
    if (ql <= l && r <= qr) {
        return lower_bound(tree[node].begin(), tree[node].end(), val) - tree[node].begin();
    }
    int mid = (l + r) / 2;
    return query(2 * node, l, mid, ql, qr, val) + query(2 * node + 1, mid + 1, r, ql, qr, val);
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);
    if (!(cin >> n >> k)) return 0;
    for (int i = 1; i <= n; i++) {
        cin >> a[i];
        if (pos[a[i]].size() >= k) b[i] = pos[a[i]][pos[a[i]].size() - k];
        else b[i] = 0;
        pos[a[i]].push_back(i);
    }
    build(1, 1, n);
    if (!(cin >> q)) return 0;
    int last = 0;
    while (q--) {
        int x, y;
        cin >> x >> y;
        int l = ((x + last) % n) + 1;
        int r = ((y + last) % n) + 1;
        if (l > r) swap(l, r);
        last = query(1, 1, n, l, r, l);
        cout << last << "\n";
    }
    return 0;
}
