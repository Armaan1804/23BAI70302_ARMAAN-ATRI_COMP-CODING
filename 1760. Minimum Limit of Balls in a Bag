class Solution:
    def isPossible(self,mid,nums,maxOperations):
        count = 0
        for n in nums:
            count += (n-1) // mid
        
        return count <= maxOperations

    def minimumSize(self, nums: List[int], maxOperations: int) -> int:
        left = 1
        right = max(nums)
        ans = right
        while left <= right:
            mid = left + (right-left) // 2
            if self.isPossible(mid,nums,maxOperations):
                ans = mid 
                right = mid - 1
            else:
                left = mid + 1
        
        return ans
        
