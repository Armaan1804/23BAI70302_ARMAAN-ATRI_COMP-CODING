class DisjointSet:
    def __init__(self,n):
        self.rank = [0] * (n+1)
        self.parent = [i for i in range(n)]
    
    def find(self, u):
        if self.parent[u] == u:
            return u
        self.parent[u] = self.find(self.parent[u])
        return self.parent[u]

    def union(self,u,v):
        pu , pv = self.find(u) , self.find(v)
        if pu == pv:
            return True
        if self.rank[pu] > self.rank[pv]:
            self.parent[pv] = pu
        elif self.rank[pu] < self.rank[pv]:
            self.parent[pu] = pv
        else:
            self.parent[pu] = pv
            self.rank[pv] += 1

        return False
class Solution:
    def makeConnected(self, n: int, connections: List[List[int]]) -> int:
        ds = DisjointSet(n)
        extra = 0
        for u , v in connections:
            if ds.union(u,v):
                extra += 1

        components = 0
        for i in range(n):
            if ds.find(i) == i:
                components += 1
        if extra >= components - 1:
            return components -1 
        return -1
